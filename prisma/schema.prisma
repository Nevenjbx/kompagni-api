// ==============================================
// CONFIGURATION PRISMA
// ==============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==============================================
// ENUMS
// ==============================================

enum Role {
  CLIENT
  PROVIDER
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum CoatType {
  SHORT
  NORMAL
  LONG
  CURLY
  DOUBLE_COAT
  MATTED
}

enum GroomingBehavior {
  EASY
  NERVOUS
  DIFFICULT
}

enum SkinCondition {
  NORMAL
  SENSITIVE
  PROBLEM
}

enum AnimalCategory {
  SMALL
  LARGE
  GIANT
  CAT
  NAC
}

enum StaffRole {
  PROFESSIONAL
  APPRENTICE
}

enum BlockType {
  FULL_DAY
  HALF_DAY
  TIME_RANGE
}

enum BlockScope {
  SALON
  STAFF
}

enum ValidationMode {
  AUTO
  MANUAL
}

// ==============================================
// UTILISATEURS
// ==============================================

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  firstName         String?
  lastName          String?
  phoneNumber       String?
  role              Role     @default(CLIENT)
  isDeleted         Boolean  @default(false)
  cancellationCount Int      @default(0)
  isBlocked         Boolean  @default(false)
  blockedReason     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  providerProfile   ProviderProfile?
  appointments      Appointment[]
  pets              Pet[]
  favoriteProviders ProviderProfile[] @relation("UserFavorites")

  @@map("users")
}

// ==============================================
// ANIMAUX (3-Layer Model)
// ==============================================

model Pet {
  id               String           @id @default(uuid())
  ownerId          String
  name             String
  species          String // 'dog' | 'cat' | 'nac'
  breedId          String
  birthDate        DateTime
  sex              String // 'male' | 'female'
  isNeutered       Boolean          @default(false)
  weightKg         Float
  category         AnimalCategory // computed from weightKg + species
  coatType         CoatType
  groomingBehavior GroomingBehavior
  skinCondition    SkinCondition    @default(NORMAL)
  lastGroomedAt    DateTime? // last grooming outside app

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner        User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  refinements  AnimalRefinement[]

  @@map("pets")
}

// ==============================================
// SALON (ex Provider)
// ==============================================

model ProviderProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  businessName String
  description  String?
  address      String
  city         String
  postalCode   String
  latitude     Float?
  longitude    Float?
  tags         String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  salonConfig  SalonConfig?
  services     Service[]
  workingHours WorkingHours[]
  absences     ProviderAbsence[]
  appointments Appointment[]
  favoritedBy  User[]            @relation("UserFavorites")
  staff        StaffMember[]
  manualBlocks ManualBlock[]

  baseRules        BaseRule[]
  modifierRules    ModifierRule[]
  priceAdjustments PriceAdjustment[]

  @@map("provider_profiles")
}

// ==============================================
// CONFIGURATION SALON
// ==============================================

model SalonConfig {
  id      String @id @default(uuid())
  salonId String @unique

  // Validation des RDV
  validationMode     ValidationMode @default(AUTO)
  pendingExpiryHours Int            @default(24)

  // Planning Pro
  slotGranularityMin  Int @default(30)
  planningHorizonDays Int @default(14)

  // Capacités simultanées (remplace GroomingTable)
  concurrentLimits Json @default("{\"SMALL\":2,\"LARGE\":1,\"GIANT\":1,\"CAT\":1,\"NAC\":1}")

  // Annulation client
  cancelDeadlineHours Int @default(24)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salon ProviderProfile @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@map("salon_configs")
}

// ==============================================
// STAFF
// ==============================================

model StaffMember {
  id      String    @id @default(uuid())
  salonId String
  name    String
  role    StaffRole

  speedIndex        Float    @default(1.0)
  allowedServiceIds String[] // service IDs this staff can perform

  // Disponibilités hebdo (JSON: [{dayOfWeek, startTime, endTime}])
  weeklySchedule Json @default("[]")
  // Congés (JSON: [{startDate, endDate, reason?}])
  leaves         Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salon        ProviderProfile @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@map("staff_members")
}

// ==============================================
// PRESTATIONS
// ==============================================

model Service {
  id          String   @id @default(uuid())
  providerId  String
  name        String
  description String?
  animalTypes String[] // ['dog', 'cat'] — which species this service applies to

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  provider     ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  baseRules    BaseRule[]

  @@map("services")
}

// ==============================================
// KAIROS ENGINE - RULES (Layer 1)
// ==============================================

model BaseRule {
  id                  String @id @default(uuid())
  salonId             String
  serviceId           String
  minWeightKg         Float
  maxWeightKg         Float // Use 9999 for "infinity" (last tier)
  baseDurationMinutes Int
  basePrice           Float // 0 for TIME_BASED
  includedMinutes     Float // 9999 for FIXED (Infinity concept)
  overtimeRatePerMin  Float // 0 for FIXED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salon   ProviderProfile @relation(fields: [salonId], references: [id], onDelete: Cascade)
  service Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([salonId, serviceId, minWeightKg])
  @@map("base_rules")
}

model ModifierRule {
  id                 String  @id @default(uuid())
  salonId            String
  triggerType        String // 'HAS_KNOTS' | 'BEHAVIOR_BAD' | 'IS_APPRENTICE' | 'FIRST_VISIT' | 'INTERVAL_LONG'
  addedMinutes       Int     @default(0)
  priceEffectFlat    Float   @default(0)
  priceEffectPercent Float   @default(0)
  isActive           Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salon ProviderProfile @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([salonId, triggerType])
  @@map("modifier_rules")
}

// ==============================================
// HORAIRES & ABSENCES
// ==============================================

model WorkingHours {
  id             String  @id @default(uuid())
  providerId     String
  dayOfWeek      Int // 0=Dim, 1=Lun, ..., 6=Sam
  startTime      String // "09:00"
  endTime        String // "18:00"
  breakStartTime String?
  breakEndTime   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  provider ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("working_hours")
}

model ProviderAbsence {
  id         String   @id @default(uuid())
  providerId String
  startDate  DateTime
  endDate    DateTime
  reason     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  provider ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("provider_absences")
}

// ==============================================
// BLOCAGES MANUELS
// ==============================================

model ManualBlock {
  id      String     @id @default(uuid())
  salonId String
  type    BlockType
  scope   BlockScope
  date    DateTime

  halfDay       String? // "MORNING" | "AFTERNOON" (si type=HALF_DAY)
  startTime     String? // "14:00" (si type=TIME_RANGE)
  endTime       String? // "15:30" (si type=TIME_RANGE)
  targetStaffId String? // FK logique (si scope=STAFF)
  reason        String?

  createdAt DateTime @default(now())

  salon ProviderProfile @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@map("manual_blocks")
}

// ==============================================
// VERROU ANTI DOUBLE-BOOKING
// ==============================================

model SlotLock {
  id        String   @id @default(uuid())
  clientId  String   // To allow lock swapping for the same user
  slotKey   String // "salonId_staffId_ISO-startTime"
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([slotKey])
  @@index([clientId])
  @@index([expiresAt])
  @@map("slot_locks")
}

// ==============================================
// RENDEZ-VOUS (Snapshot)
// ==============================================

model Appointment {
  id        String @id @default(uuid())
  clientId  String
  salonId   String
  serviceId String
  petId     String
  staffId   String

  // Mode & timing
  slotStart DateTime
  slotEnd   DateTime

  // SNAPSHOT — frozen at PENDING creation, immutable after CONFIRMED
  theoreticalDurationMinutes Int
  actualDurationMinutes      Int
  clientDurationMax          Int
  tableDurationMinutes       Int
  estimatedPrice             Float
  priceDisplayMode           String // 'exact' | 'estimate'
  priceDisplayDisclaimer     String?
  appliedModifiers           String[] // triggerType list

  // Appointment note (Layer 3 — client note for this visit)
  hasKnotsToday  Boolean @default(false)
  precautions    String?
  clientFreeNote String?

  // Statut
  status          AppointmentStatus @default(PENDING)
  rejectionReason String?
  internalNotes   String?

  lockToken     String?
  lockExpiresAt DateTime?

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  confirmedAt DateTime?
  expiresAt   DateTime? // Pour les RDV en attente de validation

  // Relations
  client  User            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  salon   ProviderProfile @relation(fields: [salonId], references: [id], onDelete: Cascade)
  service Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  pet     Pet             @relation(fields: [petId], references: [id])
  staff   StaffMember     @relation(fields: [staffId], references: [id])

  refinements      AnimalRefinement[]
  priceAdjustments PriceAdjustment[]

  @@index([salonId, slotStart])
  @@index([clientId, slotStart])
  @@index([status])
  @@index([staffId, slotStart])
  @@map("appointments")
}

// ==============================================
// REFINEMENTS & ADJUSTMENTS (Post-Appointment)
// ==============================================

model AnimalRefinement {
  id            String @id @default(uuid())
  animalId      String
  appointmentId String
  updatedBy     String // staffId

  weightKg         Float?
  coatType         CoatType?
  groomingBehavior GroomingBehavior?
  skinCondition    SkinCondition?
  toiletteurNote   String? // Internal — never shown to client

  createdAt DateTime @default(now())

  animal      Pet         @relation(fields: [animalId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("animal_refinements")
}

model PriceAdjustment {
  id            String @id @default(uuid())
  salonId       String
  appointmentId String
  addedBy       String // staffId
  amount        Float // positive = surcharge, negative = commercial gesture
  reason        String

  addedAt DateTime @default(now())

  salon       ProviderProfile @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointment Appointment     @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("price_adjustments")
}

// ==============================================
// WAITLIST
// ==============================================

model WaitlistLead {
  id      String  @id @default(uuid())
  email   String  @unique
  profile String
  city    String?

  createdAt DateTime @default(now())

  @@map("waitlist_leads")
}
