generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String            @id @default(uuid())
  email             String            @unique
  firstName         String?
  lastName          String?
  phoneNumber       String?
  role              Role              @default(CLIENT)
  isDeleted         Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  blockedReason     String?
  cancellationCount Int               @default(0)
  isBlocked         Boolean           @default(false)
  appointments      Appointment[]
  pets              Pet[]
  providerProfile   ProviderProfile?
  favoriteProviders ProviderProfile[] @relation("UserFavorites")

  @@map("users")
}

model Pet {
  id               String             @id @default(uuid())
  ownerId          String
  name             String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  birthDate        DateTime
  breedId          String
  category         AnimalCategory
  coatType         CoatType
  groomingBehavior GroomingBehavior
  isNeutered       Boolean            @default(false)
  lastGroomedAt    DateTime?
  sex              String
  skinCondition    SkinCondition      @default(NORMAL)
  species          String
  weightKg         Float
  refinements      AnimalRefinement[]
  appointments     Appointment[]
  owner            User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@map("pets")
}

model ProviderProfile {
  id               String            @id @default(uuid())
  userId           String            @unique
  businessName     String
  description      String?
  address          String
  city             String
  postalCode       String
  latitude         Float?
  longitude        Float?
  tags             String[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  appointments     Appointment[]
  baseRules        BaseRule[]
  manualBlocks     ManualBlock[]
  modifierRules    ModifierRule[]
  priceAdjustments PriceAdjustment[]
  absences         ProviderAbsence[]
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  salonConfig      SalonConfig?
  services         Service[]
  staff            StaffMember[]
  workingHours     WorkingHours[]
  favoritedBy      User[]            @relation("UserFavorites")

  @@map("provider_profiles")
}

model SalonConfig {
  id                  String          @id @default(uuid())
  salonId             String          @unique
  validationMode      ValidationMode  @default(AUTO)
  pendingExpiryHours  Int             @default(24)
  slotGranularityMin  Int             @default(30)
  planningHorizonDays Int             @default(14)
  concurrentLimits    Json            @default("{\"CAT\": 1, \"NAC\": 1, \"GIANT\": 1, \"LARGE\": 1, \"SMALL\": 2}")
  cancelDeadlineHours Int             @default(24)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  salon               ProviderProfile @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@map("salon_configs")
}

model StaffMember {
  id                String          @id @default(uuid())
  salonId           String
  name              String
  role              StaffRole
  speedIndex        Float           @default(1.0)
  allowedServiceIds String[]
  weeklySchedule    Json            @default("[]")
  leaves            Json            @default("[]")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  appointments      Appointment[]
  salon             ProviderProfile @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@map("staff_members")
}

model Service {
  id           String          @id @default(uuid())
  providerId   String
  name         String
  description  String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  animalTypes  String[]
  appointments Appointment[]
  baseRules    BaseRule[]
  provider     ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("services")
}

model BaseRule {
  id                  String          @id @default(uuid())
  salonId             String
  serviceId           String
  minWeightKg         Float
  maxWeightKg         Float
  baseDurationMinutes Int
  basePrice           Float
  includedMinutes     Float
  overtimeRatePerMin  Float
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  salon               ProviderProfile @relation(fields: [salonId], references: [id], onDelete: Cascade)
  service             Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([salonId, serviceId, minWeightKg])
  @@map("base_rules")
}

model ModifierRule {
  id                 String          @id @default(uuid())
  salonId            String
  triggerType        String
  addedMinutes       Int             @default(0)
  priceEffectFlat    Float           @default(0)
  priceEffectPercent Float           @default(0)
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  salon              ProviderProfile @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([salonId, triggerType])
  @@map("modifier_rules")
}

model WorkingHours {
  id             String          @id @default(uuid())
  providerId     String
  dayOfWeek      Int
  startTime      String
  endTime        String
  breakStartTime String?
  breakEndTime   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  provider       ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("working_hours")
}

model ProviderAbsence {
  id         String          @id @default(uuid())
  providerId String
  startDate  DateTime
  endDate    DateTime
  reason     String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("provider_absences")
}

model ManualBlock {
  id            String          @id @default(uuid())
  salonId       String
  type          BlockType
  scope         BlockScope
  date          DateTime
  halfDay       String?
  startTime     String?
  endTime       String?
  targetStaffId String?
  reason        String?
  createdAt     DateTime        @default(now())
  salon         ProviderProfile @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@map("manual_blocks")
}

model SlotLock {
  id        String   @id @default(uuid())
  slotKey   String
  expiresAt DateTime
  createdAt DateTime @default(now())
  clientId  String

  @@index([slotKey])
  @@index([clientId])
  @@index([expiresAt])
  @@map("slot_locks")
}

model Appointment {
  id                         String             @id @default(uuid())
  clientId                   String
  serviceId                  String
  status                     AppointmentStatus  @default(PENDING)
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  petId                      String
  actualDurationMinutes      Int
  appliedModifiers           String[]
  clientDurationMax          Int
  clientFreeNote             String?
  confirmedAt                DateTime?
  estimatedPrice             Float
  expiresAt                  DateTime?
  hasKnotsToday              Boolean            @default(false)
  internalNotes              String?
  lockExpiresAt              DateTime?
  lockToken                  String?
  precautions                String?
  priceDisplayDisclaimer     String?
  priceDisplayMode           String
  rejectionReason            String?
  salonId                    String
  slotEnd                    DateTime
  slotStart                  DateTime
  staffId                    String
  tableDurationMinutes       Int
  theoreticalDurationMinutes Int
  refinements                AnimalRefinement[]
  client                     User               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  pet                        Pet                @relation(fields: [petId], references: [id])
  salon                      ProviderProfile    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  service                    Service            @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff                      StaffMember        @relation(fields: [staffId], references: [id])
  priceAdjustments           PriceAdjustment[]

  @@index([salonId, slotStart])
  @@index([clientId, slotStart])
  @@index([status])
  @@index([staffId, slotStart])
  @@map("appointments")
}

model AnimalRefinement {
  id               String            @id @default(uuid())
  animalId         String
  appointmentId    String
  updatedBy        String
  weightKg         Float?
  coatType         CoatType?
  groomingBehavior GroomingBehavior?
  skinCondition    SkinCondition?
  toiletteurNote   String?
  createdAt        DateTime          @default(now())
  animal           Pet               @relation(fields: [animalId], references: [id], onDelete: Cascade)
  appointment      Appointment       @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("animal_refinements")
}

model PriceAdjustment {
  id            String          @id @default(uuid())
  salonId       String
  appointmentId String
  addedBy       String
  amount        Float
  reason        String
  addedAt       DateTime        @default(now())
  appointment   Appointment     @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  salon         ProviderProfile @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@map("price_adjustments")
}

model WaitlistLead {
  id        String   @id @default(uuid())
  email     String   @unique
  profile   String
  city      String?
  createdAt DateTime @default(now())

  @@map("waitlist_leads")
}

enum Role {
  CLIENT
  PROVIDER
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  REJECTED
  IN_PROGRESS
  NO_SHOW
}

enum CoatType {
  SHORT
  NORMAL
  LONG
  CURLY
  DOUBLE_COAT
  MATTED
}

enum GroomingBehavior {
  EASY
  NERVOUS
  DIFFICULT
}

enum SkinCondition {
  NORMAL
  SENSITIVE
  PROBLEM
}

enum AnimalCategory {
  SMALL
  LARGE
  GIANT
  CAT
  NAC
}

enum StaffRole {
  PROFESSIONAL
  APPRENTICE
}

enum BlockType {
  FULL_DAY
  HALF_DAY
  TIME_RANGE
}

enum BlockScope {
  SALON
  STAFF
}

enum ValidationMode {
  AUTO
  MANUAL
}
